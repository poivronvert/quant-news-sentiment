# Copy this file to `.env` and fill in the values.
# `.env` is gitignored and MUST NOT be committed.

# LLM endpoint — OpenAI-compatible (e.g. vLLM, llama.cpp server, OpenAI itself).
# For the local vLLM host: http://192.168.50.20:8004/v1
OPENAI_BASE_URL=http://192.168.50.20:8004/v1
OPENAI_API_KEY=

# Model identifier as registered with the inference server.
# Default for this project: gemma-4-31b-it-nvfp4 (vLLM --served-model-name).
# Switch freely (e.g. qwen2.5-7b-instruct) — never hardcode model names in code.
LLM_MODEL=gemma-4-31b-it-nvfp4

# FinMind (optional, for Taiwan market supplementary data)
FINMIND_TOKEN=
